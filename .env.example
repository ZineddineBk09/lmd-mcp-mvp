# MongoDB staging connection string
DB_URI=mongodb://localhost:27017/yacool

# Enable debug output in tool responses (_debug field)
ENABLE_DEBUG_OUTPUT=true

# ──── LLM Provider (set ONE — first found wins, ordered by free-tier size) ────
# Cerebras: 1M tokens/day FREE        → https://cloud.cerebras.ai
# CEREBRAS_API_KEY=csk-...
# Gemini:   1500 req/day FREE         → https://aistudio.google.com/apikey
# GEMINI_API_KEY=AI...
# SambaNova: 200K tok/day + $5 credit → https://cloud.sambanova.ai
# SAMBANOVA_API_KEY=...
# Groq:     100K tok/day FREE         → https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
# OpenAI:   paid                      → https://platform.openai.com
# OPENAI_API_KEY=sk-...
# Override default model for any provider:
# OPENAI_MODEL=gpt-4o


